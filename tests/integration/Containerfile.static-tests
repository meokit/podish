# syntax=docker/dockerfile:1
# Static-linked test image - copies test binaries from CMake build output
#
# Prerequisites: Build test binaries with CMake first
#   cmake -S tests/integration -B build/integration-assets -DFIBERISH_PROJECT_ROOT=$(pwd)
#   cmake --build build/integration-assets --target integration-tests-build
#
# Build: podman build --arch=386 -f Containerfile.static-tests -t localhost/fiberish-tests:static ../..

FROM scratch

# Copy pre-built test binaries from CMake output
COPY build/integration-assets/assets/ /tests/

# Default entrypoint
ENTRYPOINT ["/tests/hello_static"]
