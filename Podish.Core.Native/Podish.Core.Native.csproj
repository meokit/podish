<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Podish.Core\Podish.Core.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <OutputType>Library</OutputType>
    <AssemblyName>podishcore</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <PublishAot Condition="'$(TargetFramework)' == 'net10.0'">true</PublishAot>
    <PublishAotUsingRuntimePack Condition="'$(TargetFramework)' == 'net10.0'">true</PublishAotUsingRuntimePack>
    <NativeLib Condition="'$(TargetFramework)' == 'net10.0'">Static</NativeLib>
    <SelfContained Condition="'$(TargetFramework)' == 'net10.0'">true</SelfContained>
    <StripSymbols Condition="'$(TargetFramework)' == 'net10.0'">true</StripSymbols>
    <InvariantGlobalization Condition="'$(TargetFramework)' == 'net10.0'">true</InvariantGlobalization>
    <PodishStaticNative>true</PodishStaticNative>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <DirectPInvoke Include="fibercpu" />
  </ItemGroup>

</Project>
