<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <EnableDefaultCompileItems>true</EnableDefaultCompileItems>
  </PropertyGroup>

  <Target Name="BuildNativeLib" BeforeTargets="BeforeBuild">
    <Message Text="Building libfibercpu with CMake..." Importance="High" />
    <PropertyGroup>
      <CMakeArgs Condition="'$(PublishAot)' == 'true'">-DCMAKE_BUILD_TYPE=Release -DFIBERCPU_BUILD_STATIC=ON</CMakeArgs>
      <CMakeArgs Condition="'$(PublishAot)' != 'true'">-DCMAKE_BUILD_TYPE=Release</CMakeArgs>
    </PropertyGroup>
    <Exec Command="cmake -S ../libfibercpu -B build_native $(CMakeArgs)" WorkingDirectory="$(MSBuildThisFileDirectory)" />
    <Exec Command="cmake --build build_native --config Release" WorkingDirectory="$(MSBuildThisFileDirectory)" />
  </Target>

  <PropertyGroup Condition="'$(PublishAot)' == 'true'">
    <DefineConstants>$(DefineConstants);NATIVE_AOT</DefineConstants>
  </PropertyGroup>

  <ItemGroup Condition="'$(PublishAot)' == 'true' And $([MSBuild]::IsOsPlatform('OSX'))">
    <NativeLibrary Include="build_native/libfibercpu.a" />
  </ItemGroup>

  <ItemGroup Condition="'$(PublishAot)' == 'true' And $([MSBuild]::IsOsPlatform('Linux'))">
    <NativeLibrary Include="build_native/libfibercpu.a" />
  </ItemGroup>

  <ItemGroup Condition="'$(PublishAot)' == 'true' And $([MSBuild]::IsOsPlatform('Windows'))">
    <NativeLibrary Include="build_native/Release/fibercpu.lib" />
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOsPlatform('OSX'))">
    <Content Include="build_native/libfibercpu.dylib">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>libfibercpu.dylib</Link>
    </Content>
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOsPlatform('Linux'))">
    <Content Include="build_native/libfibercpu.so">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>libfibercpu.so</Link>
    </Content>
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOsPlatform('Windows'))">
    <Content Include="build_native/Release/fibercpu.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>fibercpu.dll</Link>
    </Content>
  </ItemGroup>

</Project>
