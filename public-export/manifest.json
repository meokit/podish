{
  "name": "public-browser-minimal",
  "default_source_ref": "main",
  "default_branch": "public-browser-minimal",
  "default_remote": "public",
  "default_remote_branch": "main",
  "default_history_mode": "append",
  "default_author_name": "GiantNeko",
  "default_author_email": "giantneko@icloud.com",
  "worktree_root": ".tmp/public-export-worktrees",
  "restore_paths": [
    "Fiberish.Core",
    "Fiberish.SilkFS",
    "Fiberish.X86",
    "Podish.Browser",
    "Podish.Core"
  ],
  "template_overrides": {
    ".gitignore": "templates/gitignore.public",
    "README.md": "templates/README.public.md",
    "Podish.slnx": "templates/Podish.public.slnx"
  },
  "text_replacements": [],
  "verify_commands": [
    [
      "dotnet",
      "build",
      "Podish.slnx",
      "-c",
      "Release"
    ]
  ]
}
